# =============================================================================
# CalorIA — Variáveis de Ambiente (PRODUÇÃO)
# Copie este arquivo para .env e preencha todos os campos.
# NUNCA commite o .env — ele está no .gitignore.
# =============================================================================

# -----------------------------------------------------------------------------
# Banco de dados
# -----------------------------------------------------------------------------
POSTGRES_USER=caloria
POSTGRES_PASSWORD=TROQUE_POR_SENHA_FORTE_AQUI
POSTGRES_DB=caloria_db
DATABASE_URL=postgresql+asyncpg://caloria:TROQUE_POR_SENHA_FORTE_AQUI@postgres:5432/caloria_db

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0

# -----------------------------------------------------------------------------
# Aplicação
# -----------------------------------------------------------------------------
APP_ENV=production
SECRET_KEY=GERE_COM_openssl_rand_-hex_32
APP_DOMAIN=seudominio.com.br

# -----------------------------------------------------------------------------
# Next.js / next-auth
# -----------------------------------------------------------------------------
NEXTAUTH_URL=https://seudominio.com.br
NEXTAUTH_SECRET=GERE_COM_openssl_rand_-hex_32
NEXT_PUBLIC_API_URL=https://seudominio.com.br

# -----------------------------------------------------------------------------
# Google Gemini (IA)
# Obtenha em: https://aistudio.google.com/app/apikey
# -----------------------------------------------------------------------------
GEMINI_API_KEY=sua_chave_gemini_aqui

# -----------------------------------------------------------------------------
# Web Push (VAPID)
# Gerado automaticamente durante o setup — veja o guia de deploy.
# VAPID_KEY_PATH aponta para o arquivo PEM no servidor.
# -----------------------------------------------------------------------------
VAPID_PUBLIC_KEY=gerado_durante_setup
VAPID_KEY_PATH=/opt/caloria/vapid_private.pem
VAPID_CLAIMS_EMAIL=seu@email.com
