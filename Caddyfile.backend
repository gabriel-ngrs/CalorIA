{$APP_DOMAIN} {
    handle /api/* {
        reverse_proxy backend:8000
    }
    handle /docs* {
        reverse_proxy backend:8000
    }
    handle /redoc* {
        reverse_proxy backend:8000
    }
    handle /openapi.json {
        reverse_proxy backend:8000
    }
    handle /health {
        reverse_proxy backend:8000
    }
    log {
        output stdout
        format console
        level INFO
    }
}
