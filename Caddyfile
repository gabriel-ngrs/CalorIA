# =============================================================================
# CalorIA — Caddyfile
# Reverse proxy com HTTPS automático via Let's Encrypt.
#
# APP_DOMAIN é injetado via variável de ambiente no docker-compose.yml.
# Exemplos de valor: caloria.seudominio.com | app.seudominio.com
# =============================================================================

{$APP_DOMAIN} {

    # ------------------------------------------------------------------
    # Next-Auth — deve ir para o frontend ANTES da regra /api/*
    # ------------------------------------------------------------------
    handle /api/auth/* {
        reverse_proxy frontend:3000
    }

    # ------------------------------------------------------------------
    # Backend — API, docs e health check
    # ------------------------------------------------------------------
    handle /api/* {
        reverse_proxy backend:8000
    }

    handle /docs* {
        reverse_proxy backend:8000
    }

    handle /redoc* {
        reverse_proxy backend:8000
    }

    handle /openapi.json {
        reverse_proxy backend:8000
    }

    handle /health {
        reverse_proxy backend:8000
    }

    # ------------------------------------------------------------------
    # Frontend — tudo o mais vai para o Next.js
    # ------------------------------------------------------------------
    handle {
        reverse_proxy frontend:3000
    }

    # ------------------------------------------------------------------
    # Logs
    # ------------------------------------------------------------------
    log {
        output stdout
        format console
        level INFO
    }
}
