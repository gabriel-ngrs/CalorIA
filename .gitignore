# =============================================================================
# CalorIA — .gitignore
# =============================================================================

# ---------------------------------------------------------------------------
# Variáveis de ambiente e segredos — NUNCA commitar
# ---------------------------------------------------------------------------
.env
.env.local
.env.*.local
*.env

# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
*.egg

# Ambientes virtuais
.venv/
venv/
env/
ENV/

# mypy
.mypy_cache/
.dmypy.json
dmypy.json

# ruff
.ruff_cache/

# Celery
celerybeat-schedule
celerybeat.pid

# pytest
.pytest_cache/
.coverage
htmlcov/
coverage.xml
*.cover

# ---------------------------------------------------------------------------
# Node.js / Next.js / Frontend
# ---------------------------------------------------------------------------
node_modules/
.next/
.next-dev/
out/
build/
dist/

# Cache
.npm
.eslintcache
.parcel-cache

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# TypeScript
*.tsbuildinfo
next-env.d.ts

# ---------------------------------------------------------------------------
# Docker
# ---------------------------------------------------------------------------
# Volumes locais (ignorar dados persistidos localmente)
postgres_data/
redis_data/
evolution_data/

# ---------------------------------------------------------------------------
# Alembic
# ---------------------------------------------------------------------------
# Não ignorar: alembic/versions/*.py são migrações commitadas

# ---------------------------------------------------------------------------
# IDE e editores
# ---------------------------------------------------------------------------
.idea/
.vscode/
.claude/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ---------------------------------------------------------------------------
# Ferramentas de automação / auditoria
# ---------------------------------------------------------------------------
.playwright-mcp/
.prints/

# ---------------------------------------------------------------------------
# Logs e temporários
# ---------------------------------------------------------------------------
*.log
logs/
tmp/
temp/
vapid_private.pem
