# =============================================================================
# CalorIA — Variáveis de Ambiente (DESENVOLVIMENTO)
# Copie este arquivo para .env e preencha com seus valores reais.
# NUNCA commite o arquivo .env.
# =============================================================================

# -----------------------------------------------------------------------------
# Banco de Dados
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://caloria:caloria@postgres:5432/caloria_db
# Para desenvolvimento local sem Docker:
# DATABASE_URL=postgresql+asyncpg://caloria:caloria@localhost:5432/caloria_db

POSTGRES_USER=caloria
POSTGRES_PASSWORD=caloria
POSTGRES_DB=caloria_db

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0
# Para desenvolvimento local sem Docker:
# REDIS_URL=redis://localhost:6379/0

# -----------------------------------------------------------------------------
# Segurança JWT
# Gere com: python -c "import secrets; print(secrets.token_hex(32))"
# -----------------------------------------------------------------------------
SECRET_KEY=sua-chave-secreta-aqui-minimo-32-caracteres
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# -----------------------------------------------------------------------------
# IA — Groq (texto e visão, free tier generoso)
# Obtenha em: https://console.groq.com/keys
# -----------------------------------------------------------------------------
GROQ_API_KEY=sua-chave-groq-aqui

# -----------------------------------------------------------------------------
# Web Push (VAPID) — necessário para notificações
# Gere com: python scripts/gen_vapid.py
# -----------------------------------------------------------------------------
VAPID_PUBLIC_KEY=sua-chave-publica-vapid
VAPID_PRIVATE_KEY=sua-chave-privada-vapid
VAPID_CLAIMS_EMAIL=seu@email.com

# -----------------------------------------------------------------------------
# Frontend — Next.js / next-auth
# Gere com: openssl rand -base64 32
# -----------------------------------------------------------------------------
NEXTAUTH_SECRET=sua-chave-nextauth-aqui
NEXTAUTH_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000

# -----------------------------------------------------------------------------
# USDA FoodData Central (importador de alimentos — opcional)
# Chave gratuita em: https://fdc.nal.usda.gov/api-guide.html
# -----------------------------------------------------------------------------
USDA_API_KEY=sua-chave-usda-aqui

# -----------------------------------------------------------------------------
# Configurações opcionais
# -----------------------------------------------------------------------------
APP_ENV=development
LOG_LEVEL=INFO
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:8000
