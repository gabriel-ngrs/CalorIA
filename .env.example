# =============================================================================
# CalorIA — Variáveis de Ambiente
# Copie este arquivo para .env e preencha com seus valores reais.
# NUNCA commite o arquivo .env
# =============================================================================

# ---------------------------------------------------------------------------
# Banco de Dados
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://caloria:caloria@postgres:5432/caloria_db
# Para desenvolvimento local sem Docker:
# DATABASE_URL=postgresql+asyncpg://caloria:caloria@localhost:5432/caloria_db

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0
# Para desenvolvimento local sem Docker:
# REDIS_URL=redis://localhost:6379/0

# ---------------------------------------------------------------------------
# Segurança JWT
# ---------------------------------------------------------------------------
# Gere com: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=sua-chave-secreta-aqui-minimo-32-caracteres
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# ---------------------------------------------------------------------------
# Google Gemini API (IA)
# Obtenha em: https://aistudio.google.com/app/apikey
# ---------------------------------------------------------------------------
GEMINI_API_KEY=sua-chave-gemini-aqui

# ---------------------------------------------------------------------------
# Telegram Bot
# Crie o bot via @BotFather no Telegram
# ---------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=seu-token-do-botfather-aqui

# ---------------------------------------------------------------------------
# Evolution API (WhatsApp)
# ---------------------------------------------------------------------------
EVOLUTION_API_URL=http://evolution_api:8080
EVOLUTION_API_KEY=sua-chave-evolution-aqui
EVOLUTION_INSTANCE_NAME=caloria

# ---------------------------------------------------------------------------
# Frontend — Next.js / next-auth
# ---------------------------------------------------------------------------
# Gere com: openssl rand -base64 32
NEXTAUTH_SECRET=sua-chave-nextauth-aqui
NEXTAUTH_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000

# ---------------------------------------------------------------------------
# PostgreSQL (credenciais do container Docker)
# ---------------------------------------------------------------------------
POSTGRES_USER=caloria
POSTGRES_PASSWORD=caloria
POSTGRES_DB=caloria_db

# ---------------------------------------------------------------------------
# Configurações opcionais
# ---------------------------------------------------------------------------
# Ambiente: development | production
APP_ENV=development
# Nível de log: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
# CORS origins permitidas (separadas por vírgula)
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:8000
