# =============================================================================
# CalorIA — EditorConfig
# https://editorconfig.org
# =============================================================================

root = true

# ---------------------------------------------------------------------------
# Padrão geral
# ---------------------------------------------------------------------------
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# ---------------------------------------------------------------------------
# Python — PEP 8 (4 espaços)
# ---------------------------------------------------------------------------
[*.py]
indent_style = space
indent_size = 4
max_line_length = 88

# ---------------------------------------------------------------------------
# TypeScript / JavaScript / JSON / CSS — padrão frontend (2 espaços)
# ---------------------------------------------------------------------------
[*.{ts,tsx,js,jsx,mjs,cjs}]
indent_style = space
indent_size = 2

[*.{json,jsonc}]
indent_style = space
indent_size = 2

[*.{css,scss}]
indent_style = space
indent_size = 2

# ---------------------------------------------------------------------------
# Markup e config
# ---------------------------------------------------------------------------
[*.{html,xml,svg}]
indent_style = space
indent_size = 2

[*.{yml,yaml}]
indent_style = space
indent_size = 2

[*.toml]
indent_style = space
indent_size = 4

# ---------------------------------------------------------------------------
# Shell scripts
# ---------------------------------------------------------------------------
[*.sh]
indent_style = space
indent_size = 2

# ---------------------------------------------------------------------------
# Makefile — obrigatório usar TAB
# ---------------------------------------------------------------------------
[Makefile]
indent_style = tab

# ---------------------------------------------------------------------------
# Markdown — sem trim de trailing whitespace (dois espaços = quebra de linha)
# ---------------------------------------------------------------------------
[*.md]
trim_trailing_whitespace = false
